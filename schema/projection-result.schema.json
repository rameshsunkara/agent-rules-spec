{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-rules.org/schema/v1/projection-result.schema.json",
  "title": "Agent Rules Projection Result",
  "type": "object",
  "required": ["outcome", "target-profile", "findings"],
  "properties": {
    "outcome": {
      "enum": ["exact", "lossy", "unsupported"]
    },
    "target-profile": {
      "type": "object",
      "required": [
        "id",
        "product",
        "surface",
        "observed",
        "evidence",
        "capabilities"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "product": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "observed": {
          "type": "string",
          "format": "date"
        },
        "evidence": {
          "type": "string",
          "format": "uri"
        },
        "capabilities": {
          "type": "object",
          "required": [
            "activation-modes",
            "path-semantics",
            "keywords",
            "priority",
            "metadata-fields"
          ],
          "properties": {
            "activation-modes": {
              "type": "array",
              "items": {
                "enum": ["always", "on-match", "manual"]
              },
              "uniqueItems": true
            },
            "path-semantics": {
              "enum": ["none", "agent-rules-1", "unverified"]
            },
            "keywords": {
              "type": "boolean"
            },
            "priority": {
              "type": "boolean"
            },
            "metadata-fields": {
              "type": "array",
              "items": {
                "enum": ["name", "description", "tags"]
              },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "required": ["filename", "frontmatter", "body"],
      "properties": {
        "filename": {
          "type": "string",
          "minLength": 1
        },
        "frontmatter": {
          "type": ["object", "null"],
          "description": "Target frontmatter, or null when the output omits it."
        },
        "body": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "code", "field", "message"],
        "properties": {
          "kind": {
            "enum": [
              "activation-loss",
              "scope-loss",
              "ordering-loss",
              "metadata-loss"
            ]
          },
          "code": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "field": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "format": "uri"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "exact"
          }
        },
        "required": ["outcome"]
      },
      "then": {
        "required": ["output"],
        "properties": {
          "findings": {
            "items": {
              "properties": {
                "kind": {
                  "const": "metadata-loss"
                }
              },
              "required": ["kind"]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "lossy"
          }
        },
        "required": ["outcome"]
      },
      "then": {
        "required": ["output"],
        "properties": {
          "findings": {
            "minItems": 1,
            "contains": {
              "properties": {
                "kind": {
                  "enum": [
                    "activation-loss",
                    "scope-loss",
                    "ordering-loss"
                  ]
                }
              },
              "required": ["kind"]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "unsupported"
          }
        },
        "required": ["outcome"]
      },
      "then": {
        "not": {
          "required": ["output"]
        },
        "properties": {
          "findings": {
            "minItems": 1,
            "contains": {
              "properties": {
                "kind": {
                  "enum": [
                    "activation-loss",
                    "scope-loss",
                    "ordering-loss"
                  ]
                }
              },
              "required": ["kind"]
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
