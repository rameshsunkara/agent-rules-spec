{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-rules.org/schema/v1/agent-rule.schema.json",
  "title": "Agent Rule Frontmatter — Document Grammar 1",
  "description": "Schema for versioned YAML frontmatter in an Agent Rules document. Legacy normalization and Markdown body parsing are specified by RFC.md and the conformance corpus.",
  "type": "object",
  "required": ["spec-version", "activation"],
  "properties": {
    "spec-version": {
      "type": "integer",
      "const": 1,
      "description": "Agent Rules document grammar."
    },
    "name": {
      "type": "string",
      "description": "Kebab-case rule identifier. When absent, the effective name is the filename stem.",
      "pattern": "^[a-z0-9](-?[a-z0-9])*$",
      "maxLength": 64
    },
    "description": {
      "type": "string",
      "description": "Opaque human-readable summary. It has no model-decided activation semantics in grammar 1.",
      "maxLength": 1024
    },
    "activation": {
      "type": "string",
      "description": "Rule selection mode. 'manual' is an experimental capability.",
      "enum": ["always", "on-match", "manual"]
    },
    "trigger": false,
    "paths": {
      "type": "array",
      "description": "Repository-relative grammar-1 glob patterns used for path selection.",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?![!/])(?!.*//)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\/$)(?!.*[{}\\[\\]\\\\]).+$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "keywords": {
      "type": "array",
      "description": "Experimental request-selection terms. Valid only as the sole condition for 'on-match'.",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "priority": {
      "type": "integer",
      "description": "Experimental advisory ordering metadata.",
      "minimum": -1000,
      "maximum": 1000
    },
    "tags": {
      "type": "array",
      "description": "Non-semantic organizational tags.",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9](-?[a-z0-9])*$",
        "maxLength": 64
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": true,
  "$comment": "Unknown fields are accepted for forward-compatible parsing. Implementations preserve and diagnose unknown unprefixed fields; their presence prohibits an exact semantic-interpretation claim.",
  "allOf": [
    {
      "if": {
        "properties": {
          "activation": {
            "const": "always"
          }
        },
        "required": ["activation"]
      },
      "then": {
        "not": {
          "anyOf": [
            {
              "required": ["paths"]
            },
            {
              "required": ["keywords"]
            }
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "activation": {
            "const": "on-match"
          }
        },
        "required": ["activation"]
      },
      "then": {
        "oneOf": [
          {
            "required": ["paths"],
            "not": {
              "required": ["keywords"]
            }
          },
          {
            "required": ["keywords"],
            "not": {
              "required": ["paths"]
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "activation": {
            "const": "manual"
          }
        },
        "required": ["activation"]
      },
      "then": {
        "not": {
          "required": ["keywords"]
        }
      }
    }
  ]
}
